# vLLM Backend Configuration
# Copy to .env and edit the values below

# === vLLM Server ===
# When running with docker-compose, use: http://vllm:8000
# When running standalone (no docker-compose), use: http://localhost:8000
VLLM_BASE_URL=http://localhost:8000

# API KEY: Only needed if your vLLM server was started with --api-key <key>
# If your vLLM docker run has NO --api-key flag (like the default), leave this empty.
# If your vLLM docker run has --api-key my-secret-key, set this to: my-secret-key
VLLM_API_KEY=

# === Proxy Server ===
PORT=3001

# === Orchestrator ===
# Default TTS voice (see https://huggingface.co/hexgrad/Kokoro-82M/blob/main/VOICES.md)
TTS_VOICE=af_bella

# vLLM model name (must match the --served-model-name in the vLLM docker command)
VLLM_MODEL=qwen3.6-35b-a3b-nvfp4