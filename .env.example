# vLLM Backend Configuration
# Copy to .env and edit the values below

# === vLLM Server ===
VLLM_BASE_URL=http://localhost:8000

# API KEY: Only needed if your vLLM server was started with --api-key <key>
# If your vLLM docker run has NO --api-key flag (like the default), leave this empty.
# If your vLLM docker run has --api-key my-secret-key, set this to: my-secret-key
VLLM_API_KEY=

# === Proxy Server ===
PORT=3001